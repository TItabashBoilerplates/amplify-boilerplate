{
	"mcpServers": {
		"context7": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp"],
			"env": {}
		},
		"magicuidesign": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@magicuidesign/mcp@latest"],
			"env": {}
		},
		"shadcn": {
			"command": "npx",
			"args": ["shadcn@latest", "mcp"]
		},
		"maestro": {
			"command": "maestro",
			"args": ["mcp"]
		},
		"devenv": {
			"transport": "stdio",
			"command": "devenv",
			"args": ["mcp"]
		},
		"figma": {
			"type": "http",
			"url": "https://mcp.figma.com/mcp"
		},
		"gemini-api-docs-mcp": {
			"type": "http",
			"url": "https://gemini-api-docs-mcp.dev"
		},
		"aws-mcp": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"mcp-proxy-for-aws@latest",
				"https://aws-mcp.us-east-1.api.aws/mcp",
				"--metadata",
				"AWS_REGION=ap-northeast-1"
			],
			"env": {}
		}
	}
}
