# Web アプリの非機密 config（雛形）。
# 使い方: このファイルを `.env.local` にコピーして値を埋める（`.env.local` は gitignore）。
#
# 方針（env/README.md 準拠）:
#   - シークレット（API キー / OAuth secret 等）は **ここに書かない**。
#     Amplify secrets（SSM）に `ampx sandbox secret set NAME` で登録する。
#   - Cognito / AppSync / S3 などの接続情報は `amplify_outputs.json`（sandbox / Hosting が生成）から
#     読むため、env には書かない。
#   - ここに置くのは公開してよい非機密の config（`NEXT_PUBLIC_*`）のみ。

# FastAPI(Python) Lambda の Function URL を上書きしたい場合に指定（通常は
# amplify_outputs.json の custom.backendApiUrl が使われるため未設定で可）。
NEXT_PUBLIC_BACKEND_PY_URL=

# クライアントのログレベル（debug | info | warn | error）。未設定なら既定値。
NEXT_PUBLIC_LOG_LEVEL=info
