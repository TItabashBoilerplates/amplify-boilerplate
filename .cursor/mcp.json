{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "magicuidesign": {
      "command": "npx",
      "args": [
        "-y",
        "@magicuidesign/mcp@latest"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "maestro": {
      "command": "maestro",
      "args": [
        "mcp"
      ]
    },
    "devenv": {
      "command": "devenv",
      "args": [
        "mcp"
      ]
    },
    "figma": {
      "url": "https://mcp.figma.com/mcp"
    },
    "gemini-api-docs-mcp": {
      "url": "https://gemini-api-docs-mcp.dev"
    }
  }
}
