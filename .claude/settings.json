{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "mcp__context7",
      "mcp__playwright",
      "mcp__magicuidesign",
      "mcp__shadcn",
      "mcp__maestro__list_devices",
      "mcp__maestro__inspect_view_hierarchy",
      "mcp__maestro__take_screenshot",
      "mcp__maestro__cheat_sheet",
      "mcp__maestro__check_flow_syntax",
      "mcp__maestro__query_docs",
      "mcp__plugin_serena_serena__activate_project",
      "mcp__plugin_serena_serena__check_onboarding_performed",
      "mcp__plugin_serena_serena__find_file",
      "mcp__plugin_serena_serena__find_referencing_symbols",
      "mcp__plugin_serena_serena__find_symbol",
      "mcp__plugin_serena_serena__get_current_config",
      "mcp__plugin_serena_serena__get_symbols_overview",
      "mcp__plugin_serena_serena__initial_instructions",
      "mcp__plugin_serena_serena__list_dir",
      "mcp__plugin_serena_serena__list_memories",
      "mcp__plugin_serena_serena__onboarding",
      "mcp__plugin_serena_serena__prepare_for_new_conversation",
      "mcp__plugin_serena_serena__read_file",
      "mcp__plugin_serena_serena__read_memory",
      "mcp__plugin_serena_serena__search_for_pattern",
      "mcp__plugin_serena_serena__switch_modes",
      "Bash(pnpm list:*)",
      "Bash(pnpm dlx shadcn@latest add:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run format:*)",
      "Bash(pnpm run format-check:*)",
      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(lint*)",
      "Bash(format*)",
      "Bash(type-check*)",
      "Bash(ci-check)",
      "Bash(bootstrap)",
      "Bash(build-frontend)",
      "Bash(build-storybook)",
      "Bash(build-mobile-ios)",
      "Bash(build-mobile-android)",
      "Bash(unit-test)",
      "Bash(e2e*)",
      "Bash(sandbox-once)",
      "Bash(stop)",
      "Bash(devenv tasks list)",
      "Bash(devenv tasks run setup:*)",
      "Bash(devenv shell -- *)"
    ],
    "deny": [
      "Bash(devenv tasks run deploy:*)",
      "Bash(ampx pipeline-deploy*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(sudo *)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": ["/tmp"]
    }
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "context7",
    "magicuidesign",
    "shadcn",
    "playwright",
    "chrome-devtools"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "direnv allow"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.command' | grep -qE '\\brm\\s+(-[a-zA-Z]*r[a-zA-Z]*\\s+|.*--recursive)' && echo 'Use trash instead of rm -rf. Example: trash <path>' && exit 2 || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/quality-check.sh",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "serena@claude-plugins-official": true,
    "cocoindex-skills@cocoindex": true,
    "example-skills@anthropic-agent-skills": true,
    "ui-design-guideline-creator@titabash-plugins": true
  }
}
